# =====================================================================
# Construction Site Safety - single source of configuration
# Copy to .env and adjust for your environment.
# =====================================================================

# -- Application ------------------------------------------------------
APP_NAME=Construction Site Safety API
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=false

# -- PostgreSQL 18.4 --------------------------------------------------
POSTGRES_USER=safety_admin
POSTGRES_PASSWORD=safety_secret_change_me
POSTGRES_DB=construction_safety
# Async driver URL used by the backend (host "postgres" inside docker-compose)
DATABASE_URL=postgresql+asyncpg://safety_admin:safety_secret_change_me@postgres:5432/construction_safety
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# -- JWT / security ---------------------------------------------------
JWT_SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# -- Seed super admin (created on first startup) ----------------------
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@safety.com
ADMIN_PASSWORD=Admin@123456

# -- Server -----------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -- Rate limiting ----------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=120/minute
RATE_LIMIT_LOGIN=10/minute

# -- Storage / logging (shared docker volume) -------------------------
DATA_DIR=/data
SCREENSHOTS_DIR=/data/screenshots
UPLOADS_DIR=/data/uploads
LOGS_DIR=/data/logs
LIVE_FRAMES_DIR=/data/live
LOG_LEVEL=INFO

# -- AI / background workers -----------------------------------------
YOLO_MODEL_PATH=yolov8n.pt
HELMET_MODEL_PATH=models/best.pt
CONFIDENCE_THRESHOLD=0.45
INFERENCE_DEVICE=cpu
FRAME_SKIP=2
MAX_ACTIVE_CAMERAS=8
ALERT_COOLDOWN_SECONDS=10
# Open a native OpenCV preview window per worker (needs a display; off in Docker).
WORKER_SHOW_WINDOW=false
# Max uploaded video size (MB) for the camera video-upload endpoint.
MAX_UPLOAD_MB=512

# -- Default safety line positions (fraction of frame height, top=0) --
GREEN_LINE_Y=0.55
YELLOW_LINE_Y=0.45
RED_LINE_Y=0.35

# -- Frontend build args (Vite) --------------------------------------
VITE_API_URL=
VITE_WS_URL=
